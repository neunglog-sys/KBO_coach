# 접속 정보 템플릿 — 실제 값은 .env 에 넣으세요 (.env 는 git 제외)
# 값은 팀 비공개 채널로 공유받아 각자 .env 작성.

# --- MongoDB Atlas (동적 야구기록: 순위·선수·경기) ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGO_DB=kbo

# --- PostgreSQL (Supabase: 유저·정적정보) ---
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# --- 백엔드 인증 (JWT 서명 키 — 랜덤 문자열) ---
JWT_SECRET=change-me-to-a-random-secret

# --- 챗봇 LLM (Google Gemini — AI Studio에서 키 발급) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite   # 선택, 미설정 시 기본값 사용

# --- (선택) 추후 기능 ---
# KMA_API_KEY=        # 날씨 /weather (기상청)
