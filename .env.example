# 접속 정보 템플릿 — 실제 값은 .env 에 넣으세요 (.env 는 git 제외)
# 값은 팀 비공개 채널로 공유받아 각자 .env 작성.

# --- MongoDB Atlas (동적 야구기록: 순위·선수·경기) ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGO_DB=kbo

# --- PostgreSQL (Supabase: 유저·정적정보) ---
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# --- 백엔드 인증 (JWT 서명 키 — 랜덤 문자열) ---
JWT_SECRET=change-me-to-a-random-secret

# --- 챗봇 LLM (Google Gemini) ---
# 운영/개발 모두 Vertex AI 사용(GCP 크레딧). 아래 4개를 .env에 넣으세요.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=kboai-5dea0
GOOGLE_CLOUD_LOCATION=global
# 서비스계정 JSON 경로 — 키 파일은 비공개 채널로 공유받아 각자 배치(git 제외됨).
GOOGLE_APPLICATION_CREDENTIALS=./kboai-5dea0-xxxxxxxx.json
# GEMINI_MODEL=gemini-3.1-flash-lite   # 선택, 미설정 시 기본값
#
# (대안) Vertex 안 쓰고 AI Studio 키로 하려면 위 GOOGLE_* 빼고 아래만:
# GEMINI_API_KEY=

# --- 푸시 알림 (Firebase FCM) ---
# 서비스 계정 키 JSON 경로. 미설정 시 repo 루트의 *firebase-adminsdk*.json 자동 탐색.
# 키 파일은 비공개 채널로 공유받아 각자 배치 (git 제외됨).
# FIREBASE_CRED_PATH=./kboai-xxxxx-firebase-adminsdk-xxxx.json

# --- (선택) 추후 기능 ---
# KMA_API_KEY=        # 날씨 /weather (기상청)
